# Flask Environment
FLASK_ENV=production
PORT=5000

# Frontend URL (for CORS) - Update with your Vercel URL
FRONTEND_URL=https://frontend-fpopzuz1e-22s-projects-de7c705f.vercel.app

# Upload Configuration
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=104857600  # 100MB in bytes

# Model Paths (future use)
MODEL_PATH=./models/saved_models

# Optional Supabase persistence to physio_app public.activity_sessions/observations
# Requires a server-side secret/service key. Do not expose this in frontend env.
# HAWKEYE_SUPABASE_URL=https://iwtyzcwiovuvmsodtusx.supabase.co
# HAWKEYE_SUPABASE_SERVICE_KEY=sb_secret_xxx_or_service_role_key
# HAWKEYE_SUPABASE_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
# HAWKEYE_SUPABASE_CREATED_BY_PERSON_ID=00000000-0000-0000-0000-000000000000
# HAWKEYE_SUPABASE_PERFORMER_PERSON_ID=00000000-0000-0000-0000-000000000000
# HAWKEYE_SUPABASE_SUBJECT_PERSON_ID=00000000-0000-0000-0000-000000000000  # optional selector hint only; must be an active org client
# HAWKEYE_SUPABASE_ACTIVITY_SESSION_ID=00000000-0000-0000-0000-000000000000  # optional; otherwise created per analysis
# HAWKEYE_SUPABASE_ACTIVITY_SESSIONS_TABLE=activity_sessions
# HAWKEYE_SUPABASE_OBSERVATIONS_TABLE=observations


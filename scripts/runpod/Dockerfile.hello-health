FROM python:3.11-slim

WORKDIR /app

COPY scripts/runpod/requirements-hello-health.txt /tmp/requirements-hello-health.txt
RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir -r /tmp/requirements-hello-health.txt

COPY scripts/runpod/hello_health_server.py /app/hello_health_server.py

ENV PYTHONUNBUFFERED=1
ENV HELLO_SERVER_HOST=0.0.0.0
ENV HELLO_SERVER_PORT=8000

EXPOSE 8000

CMD ["python", "/app/hello_health_server.py"]


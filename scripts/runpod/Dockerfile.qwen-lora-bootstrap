FROM pytorch/pytorch:2.8.0-cuda12.8-cudnn9-runtime

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

COPY scripts/runpod/requirements-hello-health.txt /tmp/requirements-bootstrap.txt
RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir -r /tmp/requirements-bootstrap.txt && \
    python -m pip install --no-cache-dir \
      pyyaml \
      transformers \
      peft \
      bitsandbytes \
      datasets \
      accelerate \
      pillow \
      opencv-python-headless \
      sentencepiece \
      protobuf

COPY scripts/runpod/qwen_lora_bootstrap_server.py /app/qwen_lora_bootstrap_server.py

ENV PYTHONUNBUFFERED=1
ENV BOOTSTRAP_SERVER_HOST=0.0.0.0
ENV BOOTSTRAP_SERVER_PORT=8000
ENV BOOTSTRAP_AUTO_START=1

EXPOSE 8000

CMD ["python", "/app/qwen_lora_bootstrap_server.py"]

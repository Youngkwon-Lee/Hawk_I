FROM pytorch/pytorch:2.8.0-cuda12.8-cudnn9-runtime

WORKDIR /app

COPY scripts/runpod/requirements-qwen-vl-server.txt /tmp/requirements-qwen-vl-server.txt

COPY scripts/runpod/qwen_vl_openai_server.py /app/qwen_vl_openai_server.py
COPY scripts/runpod/qwen_vl_fallback_server.py /app/qwen_vl_fallback_server.py
COPY scripts/runpod/start_qwen_vl_with_fallback.py /app/start_qwen_vl_with_fallback.py

ENV PYTHONUNBUFFERED=1
ENV QWEN_SERVER_HOST=0.0.0.0
ENV QWEN_SERVER_PORT=8000
ENV QWEN_MAX_NEW_TOKENS=768
ENV QWEN_SERVE_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct
ENV STARTUP_LOG_PATH=/app/startup.log

RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir torchvision --index-url https://download.pytorch.org/whl/cu128 && \
    python -m pip install --no-cache-dir -r /tmp/requirements-qwen-vl-server.txt

EXPOSE 8000

CMD ["python", "/app/start_qwen_vl_with_fallback.py"]
